{
  "name": "browserflow",
  "version": "1.0.0",
  "description": "Browser automation agent",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/index.js",
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.+(ts|js|json)\"",
    "test": "vitest",
    "run": "tsx scripts/run.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lakshyasaharan5/browserflow.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Lakshyasaharan5/browserflow/issues"
  },
  "homepage": "https://github.com/Lakshyasaharan5/browserflow#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@playwright/browser-chromium": "^1.58.2",
    "ai": "^6.0.90",
    "dotenv": "^17.3.1",
    "pino": "^10.3.1",
    "playwright": "^1.58.2",
    "tiktoken": "^1.0.22",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
